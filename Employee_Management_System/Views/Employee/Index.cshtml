@using Microsoft.AspNetCore.Http
@model List<Employee_Management_System.Models.Employee>

@{
    var role = Context.Session.GetString("Role");
}

<div class="container mt-4">

    <!-- 🔥 Top Bar -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Employee List</h2>

        <div>
            <a asp-controller="Account" asp-action="Logout" class="btn btn-danger">Logout</a>
        </div>
    </div>

    <!-- 🔍 Search Box -->
    <form method="get" asp-action="Index" class="mb-3 d-flex">
        <input type="text" name="searchString" placeholder="Search by Name or Department"
               class="form-control me-2" />
        <button type="submit" class="btn btn-primary">Search</button>
    </form>

    <!-- ➕ Add Employee (Admin Only) -->
    @if (role == "Admin")
    {
        <a class="btn btn-success mb-3" asp-action="Create">Add Employee</a>
    }

    <!-- 📊 Table -->
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Department</th>
                <th>Salary</th>

                @if (role == "Admin")
                {
                    <th>Actions</th>
                }
            </tr>
        </thead>

        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="4" class="text-center">No records found</td>
                </tr>
            }
            else
            {
                @foreach (var emp in Model)
                {
                    <tr>
                        <td>@emp.Name</td>
                        <td>@emp.Department</td>
                        <td>@emp.Salary</td>

                        @if (role == "Admin")
                        {
                            <td>
                                <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@emp.Id">Edit</a>
                                <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@emp.Id">Delete</a>
                            </td>
                        }
                    </tr>
                }
            }
        </tbody>
    </table>
</div>